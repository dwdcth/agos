# agent_memos runtime config

[general]
data_dir = "~/.memos"
default_scope = "global"
default_privacy = "private"
timezone = "Asia/Shanghai"

[store]
backend = "sqlite"                      # sqlite | postgres (future)
sqlite_path = "~/.memos/memos.db"
wal_mode = true
dict_path = "dict"                      # jieba tokenizer dict directory (for chinese-tokenizer feature)


[llm]
provider = "openai"                     # openai | anthropic | azure_openai | ollama | openrouter
model = "Qwen/Qwen3.6-35B-A3B"
api_base = "http://localhost:8000/v1"    # must include /v1 prefix (OpenAI-compatible API)
api_key = "sk-..."                                                   # 填入你的 API Key
temperature = 0.2
max_tokens = 1200
timeout_seconds = 60
enable_thinking = false                  # true to enable Qwen/DeepSeek thinking mode (reasoning_content)


[embedding]
provider = "openai"                     # openai | jina | voyage | ollama
model = "BAAI/bge-m3"
api_base = "http://localhost:8000/v1"    # must include /v1 prefix
api_key = "sk-..."                                                   # 填入你的 API Key
dimensions = 1024
batch_size = 64
timeout_seconds = 60

[vector]
backend = "sqlite_vec"                  # sqlite_vec | none
table = "object_embeddings_vec"         # sqlite-vec vec0 虚表
similarity = "cosine"                   # cosine | dot | l2

[logging]
level = "INFO"                          # DEBUG | INFO | WARNING | ERROR
json = true
path = "~/.memos/logs/app.log"
